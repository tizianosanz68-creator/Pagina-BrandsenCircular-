*{box-sizing:border-box}html,body{margin:0;width:100%;height:100%;font-family:Arial,sans-serif;overflow:hidden;color:#111827}button,input,textarea,select{font:inherit}button{cursor:pointer}#map{position:fixed;inset:0;z-index:1;background:#dbeafe}
.screen{position:fixed;inset:0;z-index:20000;background:linear-gradient(135deg,#0f172a,#14532d);display:flex;align-items:center;justify-content:center;padding:18px}.loginBox,.barrioBox{width:100%;max-width:410px;background:white;border-radius:28px;padding:26px;box-shadow:0 25px 70px #0006;text-align:center}.loginLogo{width:78px;height:78px;border-radius:24px;margin:0 auto 12px;background:linear-gradient(135deg,var(--g),var(--g2));color:white;display:flex;align-items:center;justify-content:center;font-size:40px}.loginBox h1,.barrioBox h2{margin:0;color:#14532d}.loginBox p,.barrioBox p{color:var(--m);font-size:14px;line-height:1.45}.loginBox label{display:block;text-align:left;color:#475569;font-size:13px;line-height:1.35;margin:12px 0}.loginBox button,.barrioBox button{width:100%;border:none;border-radius:18px;padding:15px;margin-top:10px;color:white;font-weight:900;background:var(--b)}.loginBox .guest,.barrioBox button{background:var(--g)}.barrioBox select{width:100%;margin-top:14px;border-radius:16px;padding:14px;border:1px solid var(--l)}#pantallaBarrio{display:none;background:white}
.topBar{position:fixed;top:14px;left:14px;right:14px;z-index:5000;display:flex;justify-content:space-between;gap:10px;pointer-events:none}.topBar button,.brandPill{pointer-events:auto;border:none;border-radius:18px;padding:13px 15px;background:white;box-shadow:0 10px 24px #0004;font-weight:900}.brandPill{color:#14532d}.changeBtn{background:var(--b)!important;color:white!important}.menuPanel{position:fixed;top:78px;left:14px;z-index:6000;width:300px;max-width:calc(100vw - 28px);background:white;border-radius:24px;padding:16px;box-shadow:0 18px 45px #0005;display:none}.menuPanel h3{margin:0 0 12px;color:#14532d}.statRow{display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid #eef2f7;font-weight:700}.menuAction{width:100%;margin-top:10px;border:none;border-radius:16px;padding:13px;background:#dcfce7;color:#166534;font-weight:900}
.fabBox{position:fixed;right:18px;bottom:28px;z-index:5000;display:flex;flex-direction:column;gap:12px;align-items:flex-end}.fab{border:none;border-radius:22px;padding:14px 18px;font-weight:900;color:white;background:linear-gradient(135deg,var(--g),var(--g2));box-shadow:0 14px 28px #0005}.plus{width:72px;height:72px;border:none;border-radius:50%;background:var(--b);color:white;font-size:42px;box-shadow:0 14px 28px #0005}.centerGuide{position:fixed;left:50%;top:50%;transform:translate(-50%,-50%);z-index:3000;pointer-events:none;width:22px;height:22px;border-radius:50%;background:var(--b);border:4px solid white;box-shadow:0 6px 14px #0006}.firma{position:fixed;bottom:10px;left:50%;transform:translateX(-50%);z-index:4000;background:#0008;color:white;border-radius:999px;padding:6px 14px;font-size:12px}
.markerCustom{width:50px;height:50px;border-radius:50%;display:flex;align-items:center;justify-content:center;color:white;font-weight:900;font-size:15px;border:4px solid white;box-shadow:0 8px 18px #0006}.basura{background:#16a34a}.calle{background:#6b7280}.luz{background:#facc15;color:#111}.cloaca{background:#2563eb}.otros{background:#8b5cf6}.ramas{background:#22c55e}.circularMark{background:#0f9f4a}.usuario{background:#2563eb}.estado{display:inline-block;padding:6px 10px;border-radius:999px;color:white;font-size:12px;font-weight:900;margin-bottom:6px}.pendiente{background:var(--a)}.proceso{background:var(--b)}.resuelto{background:var(--g)}.leaflet-popup-content-wrapper{border-radius:22px}.popupFoto{width:100%;max-width:310px;border-radius:14px;margin-top:8px}
.sheet{position:fixed;left:0;right:0;bottom:0;z-index:9000;background:white;border-radius:30px 30px 0 0;padding:20px;max-height:90vh;overflow:auto;transform:translateY(110%);transition:.28s ease;box-shadow:0 -22px 55px #0006}.sheet.open{transform:translateY(0)}.sheet h2{margin:0;color:#14532d}.hint{background:#f0fdf4;border:1px solid #bbf7d0;border-radius:16px;padding:12px;margin-top:12px;color:#14532d;font-size:14px;line-height:1.4}.sheet input,.sheet textarea,.sheet select{width:100%;border:1px solid var(--l);border-radius:16px;padding:14px;margin-top:12px;background:white}.sheet textarea{min-height:90px;resize:none}.sheet button{width:100%;border:none;border-radius:18px;padding:15px;margin-top:12px;font-weight:900}.btnPrimary{background:var(--g);color:white}.btnSecondary{background:#e5e7eb;color:#111}.aiResult{display:none;margin-top:12px;border:1px solid #bbf7d0;background:#f0fdf4;border-radius:18px;padding:14px;color:#14532d}
#overlayCircular{position:fixed;inset:0;background:#0007;z-index:9997;display:none}#panelCircular{position:fixed;left:0;right:0;bottom:0;background:white;z-index:9998;border-radius:30px 30px 0 0;padding:22px;max-height:90vh;overflow:auto;transform:translateY(110%);transition:.3s;box-shadow:0 -24px 60px #0007}.circularHead{display:flex;justify-content:space-between;gap:12px;align-items:flex-start}.circularHead h2{margin:0;font-size:30px;color:#111827}.circularHead p{margin:5px 0 0;color:var(--m);font-size:17px;line-height:1.25}.closeCircular{min-width:58px;width:58px;height:58px;border:none;border-radius:50%;font-size:34px;background:#eef2f7;color:#111827}.circularTabs{background:#f1f5f9;border-radius:26px;padding:10px;margin-top:18px}.circularTabs button{width:100%;border:none;border-radius:19px;padding:18px;background:transparent;font-size:20px;font-weight:900;color:#111827}.circularTabs button.active{background:#dcfce7;color:#166534}.circularBox{border:1px solid var(--l);border-radius:24px;padding:17px;margin-top:18px;font-size:17px;line-height:1.45;background:white}.categoryPill{display:inline-block;margin-top:8px;border-radius:999px;padding:8px 12px;background:#dcfce7;color:#166534;font-weight:900}.retCard{border:1px solid var(--l);border-radius:24px;padding:20px;margin-top:18px;background:white;box-shadow:0 8px 22px #0001}.retCard .icono{font-size:38px;margin-bottom:8px}.retCard h3{margin:0;font-size:23px}.retCard p{margin:7px 0;color:var(--m);font-size:17px;line-height:1.35}.retCard button{width:100%;margin-top:16px;border:none;border-radius:18px;padding:17px;background:var(--g);color:white;font-size:19px;font-weight:900}.adminSmall{font-size:14px;color:#14532d;background:#f0fdf4;border:1px solid #bbf7d0;border-radius:16px;padding:10px;margin-top:12px}
@media(max-width:620px){.brandPill{display:none}#panelCircular{padding:20px 16px}.circularHead h2{font-size:28px}}
</style>
