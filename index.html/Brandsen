<body>
<div id="pantallaLogin" class="screen"><div class="loginBox"><div class="loginLogo">♻</div><h1>Brandsen Reclamos</h1><p>Mapa de reclamos ciudadanos con IA circular para ofrecer recursos a la comunidad.</p><label><input type="checkbox" id="acepto"> Acepto términos y privacidad para usar la app.</label><button onclick="loginSeguro()">Ingresar con Google</button><button class="guest" onclick="entrarInvitado()">Entrar como invitado</button></div></div>
<div id="pantallaBarrio" class="screen"><div class="barrioBox"><h2>Elegí tu barrio</h2><p>Vas a ver reclamos y recursos del barrio seleccionado.</p><select id="barrio"><option>Radio centrico</option><option>Barrio republica</option><option>Los pinos</option><option>Las higueras</option><option>El soñado</option><option>El matadero</option><option>Retama</option><option>La manzana</option><option>La rural</option><option>La dolly 1</option><option>La dolly 2</option><option>Las americas</option><option>La parada</option><option>Bajo belgrano</option><option>Los naranjos</option><option>I.isabel</option><option>Las mandarinas</option><option>Jeppener</option><option>Altamirano</option><option>Los bosquecitos</option><option>Gomez</option><option>Las golondrinas</option><option>Las acacias</option></select><button onclick="guardarBarrio()">Entrar</button></div></div>
<div class="topBar"><button onclick="toggleMenu()">☰</button><div class="brandPill">♻ Reclamos + Comunidad Circular</div><button class="changeBtn" onclick="cambiarBarrio()">Cambiar barrio</button></div>
<div id="menuPanel" class="menuPanel"><h3>Panel rápido</h3><div class="statRow"><span>Total</span><span id="total">0</span></div><div class="statRow"><span>Basura</span><span id="basura">0</span></div><div class="statRow"><span>Calle</span><span id="calle">0</span></div><div class="statRow"><span>Luminaria</span><span id="luz">0</span></div><div class="statRow"><span>Cloacas</span><span id="cloaca">0</span></div><div class="statRow"><span>Otros</span><span id="otros">0</span></div><div class="statRow"><span>Recursos IA</span><span id="circulares">0</span></div><button class="menuAction" onclick="abrirCircular()">♻ Ofrecer a la comunidad</button></div>
<div id="map"></div><div class="centerGuide"></div><div class="firma">Created by Tiziano Sanz</div>
<div class="fabBox"><button class="fab" onclick="abrirCircular()">♻ Ofrecer a la comunidad</button><button class="plus" onclick="abrirForm()">+</button></div>
<div id="formModal" class="sheet"><h2>Nuevo reclamo</h2><div class="hint">La IA revisa el texto y detecta sola si puede ser reutilizable o reciclable.</div><select id="tipo" onchange="preAnalizar()"><option>Basura</option><option>Calle</option><option>Luminaria</option><option>Cloacas</option><option>Otros</option><option>Ramas / Poda</option><option>Barrido</option><option>Zanjeo</option><option>Zona verde</option></select><textarea id="desc" placeholder="Descripción. Ej: hay pallets, cajones, botellas, cables, ramas..." oninput="preAnalizar()"></textarea><button class="btnSecondary" onclick="hablar()">🎤 Dictar</button><input type="file" id="foto" accept="image/*"><div id="aiResult" class="aiResult"></div><div id="barraCarga" style="display:none;margin-top:10px;"><div style="background:#e5e7eb;border-radius:10px;overflow:hidden;"><div id="progreso" style="height:10px;width:0%;background:#2563eb;"></div></div><small id="textoProgreso">Subiendo 0%</small></div><button class="btnPrimary" onclick="guardar()">Publicar</button><button class="btnSecondary" onclick="cerrarForm()">Cancelar</button></div>
<div id="overlayCircular" onclick="cerrarCircular()"></div>
<div id="panelCircular"><div class="circularHead"><div><h2>♻️ Ofrecer a la comunidad</h2><p>Opción ciudadana para recuperar materiales útiles sin confundir el mapa de reclamos.</p></div><button class="closeCircular" onclick="cerrarCircular()">×</button></div><div class="circularTabs"><button id="tabRet" class="active" onclick="mostrarCircular('retiradores')">Recuperadores Circulares</button><button id="tabRec" onclick="mostrarCircular('recursos')">Recursos Ofrecidos</button><button id="tabSol" onclick="mostrarCircular('solicitudes')">Solicitudes</button></div><div id="boxRetiradores"><div class="circularBox">El vecino no ve WhatsApp directo. La solicitud llega primero al administrador para revisar y derivar.<div class="adminSmall">Las solicitudes son revisadas por administración antes de derivarse.</div><div id="categoriaActualCircular" class="categoryPill">Categoría: A revisar</div></div><div id="listaRetiradores"></div></div><div id="boxRecursos" style="display:none;"><div class="circularBox">Recursos detectados por IA desde los reclamos del barrio.</div><div id="listaRecursosCircular"></div></div><div id="boxSolicitudes" style="display:none;"><div class="circularBox">Solicitudes enviadas para revisión del administrador.</div><div id="listaSolicitudes"></div></div></div>
<script>
function normalizarTelefonoAR(input){let n=String(input||"").replace(/\D/g,"");if(n.startsWith("549"))return n;if(n.startsWith("54"))return"549"+n.slice(2);if(n.startsWith("0"))n=n.slice(1);return"549"+n}
const ADMIN_WHATSAPP=normalizarTelefonoAR("2223513637");
firebase.initializeApp({apiKey:"AIzaSyCAugMeB_lM2pz4x4Ywgp3ahviFkKNZOXY",authDomain:"registros-online-brandsen.firebaseapp.com",projectId:"registros-online-brandsen",storageBucket:"registros-online-brandsen.firebasestorage.app"});
const auth=firebase.auth(),db=firebase.firestore(),storage=firebase.storage(),provider=new firebase.auth.GoogleAuthProvider();
cargarRecuperadoresFirebase();
let unsubscribe=null,map,marcadorUsuario,marcadores=[],modoInvitado=false,reclamosDemo=[],reclamosActuales=[],solicitudesLocales=[];
let solicitudActual={categoria:"a_revisar",categoriaTexto:"A revisar",material:"A revisar",detalle:"",barrio:"",lat:null,lng:null,id:null};
let recuperadoresFirebase={a_revisar:[{nombre:"Administrador Circular",rubro:"Revisión manual y derivación segura",zona:"Brandsen",icono:"🛡️"}]};

function iconoCategoria(cat){
 if(cat==="madera") return "🪵";
 if(cat==="plastico") return "♻️";
 if(cat==="electronica") return "💻";
 if(cat==="poda") return "🌿";
 if(cat==="metal") return "🔩";
 if(cat==="carton") return "📦";
 if(cat==="obra") return "🚜";
 return "🛡️";
}
function cargarRecuperadoresFirebase(){
 db.collection("recuperadores_circulares").where("activo","==",true).onSnapshot(snap=>{
   let temp={};
   snap.forEach(doc=>{
     let r=doc.data();
     let cat=r.categoria||"a_revisar";
     if(!temp[cat]) temp[cat]=[];
     temp[cat].push({
       nombre:r.nombre||"Recuperador",
       rubro:r.rubro||"",
       zona:r.zona||"Brandsen",
       icono:iconoCategoria(cat)
     });
   });
   if(Object.keys(temp).length===0){
      temp={a_revisar:[{nombre:"Administrador Circular",rubro:"Revisión manual y derivación segura",zona:"Brandsen",icono:"🛡️"}]};
   }
   recuperadoresFirebase=temp;
 });
}
async function loginSeguro(){if(!document.getElementById("acepto").checked){alert("Aceptá términos");return}try{await auth.signInWithPopup(provider)}catch(e){try{await auth.signInWithRedirect(provider)}catch(err){alert("No se pudo iniciar con Google. Revisá dominios autorizados en Firebase.");console.error(err)}}}
function entrarInvitado(){modoInvitado=true;pantallaLogin.style.display="none";if(!localStorage.getItem("barrio"))pantallaBarrio.style.display="flex";else initMapa()}
auth.onAuthStateChanged(user=>{if(modoInvitado)return;if(!user){pantallaLogin.style.display="flex";return}pantallaLogin.style.display="none";if(!localStorage.getItem("barrio"))pantallaBarrio.style.display="flex";else initMapa()});
function guardarBarrio(){localStorage.setItem("barrio",barrio.value);pantallaBarrio.style.display="none";if(map){cargar();setTimeout(()=>map.invalidateSize(),100)}else initMapa()}
function cambiarBarrio(){pantallaBarrio.style.display="flex"}
function initMapa(){if(map){cargar();setTimeout(()=>map.invalidateSize(),100);return}map=L.map("map").setView([-35.21,-58.23],13);let mb=L.tileLayer("https://api.mapbox.com/styles/v1/mapbox/satellite-streets-v12/tiles/{z}/{x}/{y}?access_token=pk.eyJ1IjoibHVrYXNzc3NzIiwiYSI6ImNtbnFjem9nZDA2ZGwyb29kdTZsaHE4cmQifQ.0pT5NUsfROkL4CMjq4r_wA",{tileSize:512,zoomOffset:-1,maxZoom:20}).addTo(map);mb.on("tileerror",()=>L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png",{maxZoom:19}).addTo(map));navigator.geolocation.getCurrentPosition(p=>map.setView([p.coords.latitude,p.coords.longitude],17),()=>{});navigator.geolocation.watchPosition(p=>{let lat=p.coords.latitude,lng=p.coords.longitude;if(!marcadorUsuario){marcadorUsuario=L.marker([lat,lng],{icon:L.divIcon({html:`<div class="markerCustom usuario">YO</div>`,className:"",iconSize:[50,50],iconAnchor:[25,25]})}).addTo(map)}else marcadorUsuario.setLatLng([lat,lng])});cargar()}
function normalizar(t){return(t||"").toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g,"")}
function detectarCircular(desc,tipo){let t=normalizar(desc+" "+tipo);if(t.includes("madera")||t.includes("pallet")||t.includes("palet")||t.includes("mueble")||t.includes("cajon")||t.includes("mesa")||t.includes("silla"))return{reciclable:true,categoria:"madera",texto:"Muebles y madera reutilizable",alerta:"♻ Recurso aprovechable detectado"};if(t.includes("plastico")||t.includes("botella")||t.includes("bidon")||t.includes("envase")||t.includes("tapita"))return{reciclable:true,categoria:"plastico",texto:"Plásticos y envases reciclables",alerta:"♻ Plástico recuperable detectado"};if(t.includes("tv")||t.includes("pc")||t.includes("computadora")||t.includes("cable")||t.includes("celular")||t.includes("electronica")||t.includes("electrónica"))return{reciclable:true,categoria:"electronica",texto:"Electrónica / RAEE",alerta:"♻ Electrónica recuperable detectada"};if(t.includes("rama")||t.includes("poda")||t.includes("hoja")||t.includes("arbol")||tipo==="Ramas / Poda")return{reciclable:true,categoria:"poda",texto:"Restos verdes para compost o chipiado",alerta:"♻ Restos verdes detectados"};if(t.includes("metal")||t.includes("caño")||t.includes("chatarra")||t.includes("hierro"))return{reciclable:true,categoria:"metal",texto:"Metales y caños recuperables",alerta:"♻ Metal recuperable detectado"};if(t.includes("carton")||t.includes("cartón")||t.includes("papel")||t.includes("caja"))return{reciclable:true,categoria:"carton",texto:"Cartón y papel reciclable",alerta:"♻ Cartón reciclable detectado"};if(t.includes("escombro")||t.includes("ladrillo")||t.includes("arena")||t.includes("obra"))return{reciclable:true,categoria:"obra",texto:"Materiales de obra recuperables",alerta:"♻ Material de obra recuperable"};return{reciclable:false,categoria:"a_revisar",texto:"No detectado",alerta:""}}
function preAnalizar(){let ev=detectarCircular(desc.value,tipo.value);if(ev.reciclable){aiResult.style.display="block";aiResult.innerHTML=`<b>${ev.alerta}</b><br>Categoría: ${ev.texto}<br>Al publicar, el popup ofrecerá solicitar revisión circular.`}else aiResult.style.display="none"}
function icono(tipo,ev){let c="otros",txt="OT";if(ev&&ev.reciclable){c="circularMark";txt="♻"}else{if(tipo==="Basura"){c="basura";txt="BA"}if(tipo==="Calle"){c="calle";txt="CA"}if(tipo==="Luminaria"){c="luz";txt="LU"}if(tipo==="Cloacas"){c="cloaca";txt="CL"}if(tipo==="Ramas / Poda"){c="ramas";txt="RP"}}return L.divIcon({html:`<div class="markerCustom ${c}">${txt}</div>`,className:"",iconSize:[50,50],iconAnchor:[25,25]})}
function cargar(){if(unsubscribe)unsubscribe();marcadores.forEach(m=>map.removeLayer(m));marcadores=[];reclamosActuales=[];if(modoInvitado){cargarDemo();return}unsubscribe=db.collection("reclamos").onSnapshot(s=>procesarSnap(s),e=>{console.error(e);alert("No se pudieron cargar reclamos. Revisá reglas de Firebase.")})}
function procesarSnap(snap){marcadores.forEach(m=>map.removeLayer(m));marcadores=[];reclamosActuales=[];let s={total:0,basura:0,calle:0,luz:0,cloaca:0,otros:0,circulares:0},b=localStorage.getItem("barrio");snap.forEach(doc=>{let d={id:doc.id,...doc.data()};if(d.barrio!==b)return;procesarReclamo(d,s)});actualizarStats(s);renderRecursosCircular()}
function cargarDemo(){if(reclamosDemo.length===0){let b=localStorage.getItem("barrio")||"Los pinos";reclamosDemo=[{id:"demo1",tipo:"Basura",desc:"Cajones de madera y pallets en la vereda",barrio:b,lat:-35.169,lng:-58.234,estado:"pendiente"},{id:"demo2",tipo:"Luminaria",desc:"Luz apagada en esquina",barrio:b,lat:-35.170,lng:-58.236,estado:"pendiente"},{id:"demo3",tipo:"Ramas / Poda",desc:"Ramas acumuladas para retirar",barrio:b,lat:-35.171,lng:-58.233,estado:"pendiente"},{id:"demo4",tipo:"Otros",desc:"TV vieja y cables para retirar",barrio:b,lat:-35.172,lng:-58.237,estado:"pendiente"}]}let st={total:0,basura:0,calle:0,luz:0,cloaca:0,otros:0,circulares:0};reclamosDemo.forEach(d=>procesarReclamo(d,st));actualizarStats(st);renderRecursosCircular()}
function procesarReclamo(d,st){let ev=detectarCircular(d.desc||"",d.tipo||"");reclamosActuales.push({...d,ev});st.total++;if(d.tipo==="Basura")st.basura++;if(d.tipo==="Calle")st.calle++;if(d.tipo==="Luminaria")st.luz++;if(d.tipo==="Cloacas")st.cloaca++;if(d.tipo==="Otros")st.otros++;if(ev.reciclable)st.circulares++;let estado=d.estado||"pendiente",ec=estado==="resuelto"?"resuelto":estado==="en_proceso"?"proceso":"pendiente";let html=`<span class="estado ${ec}">${estado}</span><br><b>${d.tipo||"Reclamo"}</b><br><div>${d.desc||""}</div>`;if(d.foto)html+=`<br><img class="popupFoto" src="${d.foto}">`;if(ev.reciclable)html+=`<div style="background:#f0fdf4;border:1px solid #bbf7d0;border-radius:14px;padding:10px;margin-top:10px"><b>${ev.alerta}</b><br>Categoría: ${ev.texto}</div><br><button style="background:#16a34a;color:white;border:none;border-radius:12px;padding:10px;width:100%;font-weight:900" onclick='prepararCircularDesdeReclamo(${JSON.stringify({...d,ev})})'>♻ Solicitar revisión circular</button>`;html+=`<br><a href="https://www.google.com/maps?q=${d.lat},${d.lng}" target="_blank">📍 Cómo llegar</a>`;let m=L.marker([d.lat,d.lng],{icon:icono(d.tipo,ev)}).addTo(map).bindPopup(html);marcadores.push(m)}
function actualizarStats(s){total.innerText=s.total;basura.innerText=s.basura;calle.innerText=s.calle;luz.innerText=s.luz;cloaca.innerText=s.cloaca;otros.innerText=s.otros;circulares.innerText=s.circulares}
function abrirForm(){formModal.classList.add("open");preAnalizar()}function cerrarForm(){formModal.classList.remove("open")}function toggleMenu(){menuPanel.style.display=menuPanel.style.display==="block"?"none":"block"}function hablar(){if(!window.webkitSpeechRecognition){alert("Tu navegador no soporta dictado.");return}let r=new webkitSpeechRecognition();r.lang="es-AR";r.start();r.onresult=e=>{desc.value+=" "+e.results[0][0].transcript;preAnalizar()}}
async function guardar(){try{let tipoVal=tipo.value,descVal=desc.value.trim(),barrio=localStorage.getItem("barrio")||"Sin barrio",file=foto.files[0];if(!descVal){alert("Escribí una descripción.");return}let lat=map.getCenter().lat,lng=map.getCenter().lng,ev=detectarCircular(descVal,tipoVal),urlFoto="";if(modoInvitado){reclamosDemo.push({id:"demo"+Date.now(),tipo:tipoVal,desc:descVal,barrio,lat,lng,foto:"",estado:"pendiente",fecha:Date.now()});limpiarForm();cerrarForm();cargar();alert("Reclamo demo creado ✅");return}if(file){barraCarga.style.display="block";let ref=storage.ref().child("reclamos/"+Date.now()+"_"+file.name),tarea=ref.put(file);await new Promise((res,rej)=>{tarea.on("state_changed",snap=>{let pct=Math.round((snap.bytesTransferred/snap.totalBytes)*100);progreso.style.width=pct+"%";textoProgreso.innerText="Subiendo "+pct+"%"},rej,async()=>{urlFoto=await tarea.snapshot.ref.getDownloadURL();res()})});barraCarga.style.display="none"}let user=auth.currentUser;await db.collection("reclamos").add({tipo:tipoVal,desc:descVal,barrio,lat,lng,foto:urlFoto,estado:"pendiente",fecha:Date.now(),email:user?user.email:null,circularIA:ev.reciclable,categoriaCircular:ev.categoria,categoriaTexto:ev.texto});limpiarForm();cerrarForm();alert("Reclamo creado ✅")}catch(e){console.error(e);alert("Error al guardar: "+e.message)}}
function limpiarForm(){desc.value="";foto.value="";barraCarga.style.display="none";aiResult.style.display="none"}
function abrirCircular(){overlayCircular.style.display="block";panelCircular.style.transform="translateY(0)";renderRetiradores();renderRecursosCircular();renderSolicitudes()}function cerrarCircular(){overlayCircular.style.display="none";panelCircular.style.transform="translateY(110%)"}
function mostrarCircular(t){tabRet.classList.remove("active");tabRec.classList.remove("active");tabSol.classList.remove("active");boxRetiradores.style.display="none";boxRecursos.style.display="none";boxSolicitudes.style.display="none";if(t==="retiradores"){tabRet.classList.add("active");boxRetiradores.style.display="block";renderRetiradores()}if(t==="recursos"){tabRec.classList.add("active");boxRecursos.style.display="block";renderRecursosCircular()}if(t==="solicitudes"){tabSol.classList.add("active");boxSolicitudes.style.display="block";renderSolicitudes()}}
function prepararCircularDesdeReclamo(d){solicitudActual={categoria:d.ev?d.ev.categoria:"a_revisar",categoriaTexto:d.ev?d.ev.texto:"A revisar",material:d.ev?d.ev.texto:"A revisar",detalle:d.desc||"",barrio:d.barrio||localStorage.getItem("barrio")||"Brandsen",lat:d.lat,lng:d.lng,id:d.id||null};abrirCircular();mostrarCircular("retiradores")}
function renderRetiradores(){let cat=solicitudActual.categoria||"a_revisar";categoriaActualCircular.innerText="Categoría: "+(solicitudActual.categoriaTexto||"A revisar");let lista=recuperadoresFirebase[cat]||recuperadoresFirebase.a_revisar;listaRetiradores.innerHTML="";lista.forEach((r,i)=>{let div=document.createElement("div");div.className="retCard";div.innerHTML=`<div class="icono">${r.icono}</div><h3>${r.nombre}</h3><p>${r.rubro}</p><p>Zona: ${r.zona}</p><button onclick="enviarSolicitudAdmin(${i})">Solicitar revisión</button>`;listaRetiradores.appendChild(div)})}
function renderRecursosCircular(){if(!document.getElementById("listaRecursosCircular"))return;listaRecursosCircular.innerHTML="";let recursos=reclamosActuales.filter(r=>r.ev&&r.ev.reciclable);if(recursos.length===0){listaRecursosCircular.innerHTML=`<div class="circularBox">Todavía no hay recursos detectados por IA en este barrio.</div>`;return}recursos.forEach(r=>{let div=document.createElement("div");div.className="retCard";div.innerHTML=`<div class="icono">♻️</div><h3>${r.ev.texto}</h3><p>${r.desc||""}</p><p>Zona: ${r.barrio||""}</p><button onclick='prepararCircularDesdeReclamo(${JSON.stringify(r)})'>Ofrecer a la comunidad</button>`;listaRecursosCircular.appendChild(div)})}
async function enviarSolicitudAdmin(i){let cat=solicitudActual.categoria||"a_revisar",lista=recuperadoresFirebase[cat]||recuperadoresFirebase.a_revisar,r=lista[i],ubicacion="No informada";if(solicitudActual.lat&&solicitudActual.lng)ubicacion="https://www.google.com/maps?q="+solicitudActual.lat+","+solicitudActual.lng;else if(map&&map.getCenter){let c=map.getCenter();ubicacion="https://www.google.com/maps?q="+c.lat+","+c.lng}let data={fecha:Date.now(),estado:"pendiente_admin",recuperadorSugerido:r.nombre,rubro:r.rubro,categoria:solicitudActual.categoriaTexto||"A revisar",barrio:solicitudActual.barrio||localStorage.getItem("barrio")||"Brandsen",detalle:solicitudActual.detalle||"Solicitud circular",ubicacion,reclamoId:solicitudActual.id||null};solicitudesLocales.unshift(data);if(!modoInvitado){try{await db.collection("solicitudesCircular").add(data)}catch(e){console.log("Solicitud solo por WhatsApp:",e.message)}}let mensaje=`Nueva solicitud BrandsenCircular

Objetivo: mejora ciudadana, ecología y limpieza.

Categoría: ${data.categoria}
Recuperador sugerido: ${data.recuperadorSugerido}
Rubro: ${data.rubro}
Barrio/Zona: ${data.barrio}
Detalle: ${data.detalle}

Ubicación:
${data.ubicacion}

La solicitud llega primero al administrador para revisar y derivar.`;window.location.href="https://api.whatsapp.com/send?phone="+ADMIN_WHATSAPP+"&text="+encodeURIComponent(mensaje)}
async function renderSolicitudes(){listaSolicitudes.innerHTML="";if(modoInvitado){renderSolicitudesLocal();return}try{let snap=await db.collection("solicitudesCircular").orderBy("fecha","desc").limit(10).get();if(snap.empty){renderSolicitudesLocal();return}snap.forEach(doc=>{let s=doc.data(),div=document.createElement("div");div.className="retCard";div.innerHTML=`<div class="icono">📋</div><h3>${s.categoria||"Solicitud"}</h3><p>${s.detalle||""}</p><p>Estado: ${s.estado||"pendiente"}</p>`;listaSolicitudes.appendChild(div)})}catch(e){renderSolicitudesLocal()}}
function renderSolicitudesLocal(){if(solicitudesLocales.length===0){listaSolicitudes.innerHTML=`<div class="circularBox">Todavía no hay solicitudes enviadas.</div>`;return}solicitudesLocales.forEach(s=>{let div=document.createElement("div");div.className="retCard";div.innerHTML=`<div class="icono">📋</div><h3>${s.categoria}</h3><p>${s.detalle}</p><p>Estado: ${s.estado}</p>`;listaSolicitudes.appendChild(div)})}
</script>
